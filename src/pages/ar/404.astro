---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { useTranslations } from '~/i18n/index';

const lang = 'ar' as const;
const t = await useTranslations(lang);
---
<BaseLayout
  title={t('meta.404_title')}
  description={t('meta.404_desc')}
  noindex={true}
  lang={lang}
>
  <section class="hero" style="text-align:center;">
    <div class="container">
      <span class="eyebrow" style="justify-content:center;">{t('p404.eyebrow')}</span>
      <h1 class="h-display" style="margin:24px auto;max-width:18ch;">{t('p404.heading')}</h1>
      <p class="lede" style="margin:0 auto 36px;max-width:48ch;">{t('p404.lede')}</p>
      <a href="/ar" class="btn btn-primary">{t('p404.btn')}</a>
    </div>
  </section>
</BaseLayout>
