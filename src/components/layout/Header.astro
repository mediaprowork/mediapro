---
import Icon from '~/components/icons/Icon.astro';
import { SITE } from '~/data/site';
import type { Lang } from '~/i18n/index';
import { useTranslations } from '~/i18n/index';
import LangSwitcher from '~/components/ui/LangSwitcher.astro';
interface Props { active?: 'home'|'about'|'services'|'contact'; homeBase?: string; lang?: Lang; }
const { active, homeBase = '/', lang = 'en' } = Astro.props;
const t = await useTranslations(lang);
const contactHref = lang === 'en' ? '/contact' : `/${lang}/contact`;
const localizedHomeBase = homeBase === '/' && lang !== 'en' ? `/${lang}` : homeBase;
---

<header class="site-header" role="banner">
  <div class="nav-inner">
    <a href={localizedHomeBase} class="brand" aria-label={`${SITE.name} — Home`}>
      <img src="/logo-text.png" alt="Media Pro" width="130" height="43" />
    </a>

    <nav aria-label="Primary navigation">
      <ul class="nav-links">
        <li><a href={localizedHomeBase} aria-current={active === 'home' ? 'page' : undefined}>{t('nav.home')}</a></li>
        <li><a href={`${localizedHomeBase}#about`} aria-current={active === 'about' ? 'page' : undefined}>{t('nav.about')}</a></li>
        <li><a href={`${localizedHomeBase}#services`} aria-current={active === 'services' ? 'page' : undefined}>{t('nav.services')}</a></li>
        <li><a href={contactHref} aria-current={active === 'contact' ? 'page' : undefined}>{t('nav.contact')}</a></li>
      </ul>
    </nav>

    <LangSwitcher currentLang={lang} />

    <a href={contactHref} class="btn btn-primary nav-cta">
      {t('nav.cta')}
      <Icon name="arrow-right" size={14} />
    </a>

    <!-- Hamburger: two-line minimal design -->
    <button
      class="menu-btn"
      id="menuBtn"
      aria-label={t('nav.menu_open')}
      aria-expanded="false"
      aria-controls="navSidebar"
      type="button"
    >
      <span class="hb-line hb-top"></span>
      <span class="hb-line hb-bot"></span>
    </button>
  </div>
</header>

<!-- Backdrop — pointer-events controlled by JS -->
<div class="nav-backdrop" id="navBackdrop" aria-hidden="true"></div>

<!-- Sidebar drawer -->
<aside class="nav-sidebar" id="navSidebar" aria-label="Mobile navigation" aria-hidden="true">
  <button class="sidebar-close" id="sidebarClose" aria-label={t('nav.menu_close')} type="button">
    <span class="sc-line"></span>
    <span class="sc-line"></span>
  </button>
  <nav>
    <ul class="sidebar-links">
      <li><a href={localizedHomeBase} aria-current={active === 'home' ? 'page' : undefined}>{t('nav.home')}</a></li>
      <li><a href={`${localizedHomeBase}#about`} aria-current={active === 'about' ? 'page' : undefined}>{t('nav.about')}</a></li>
      <li><a href={`${localizedHomeBase}#services`} aria-current={active === 'services' ? 'page' : undefined}>{t('nav.services')}</a></li>
      <li><a href={contactHref} aria-current={active === 'contact' ? 'page' : undefined}>{t('nav.contact')}</a></li>
    </ul>
  </nav>

  <div class="sidebar-footer">
    <LangSwitcher currentLang={lang} />
    <a href={contactHref} class="btn btn-primary sidebar-cta-btn">
      {t('nav.cta')}
      <Icon name="arrow-right" size={14} />
    </a>
  </div>
</aside>

<script>
  import '~/lib/header-scroll';

  const btn      = document.getElementById('menuBtn')     as HTMLButtonElement | null;
  const sidebar  = document.getElementById('navSidebar')  as HTMLElement | null;
  const backdrop = document.getElementById('navBackdrop') as HTMLElement | null;
  const closeBtn = document.getElementById('sidebarClose') as HTMLButtonElement | null;

  function open() {
    if (!btn || !sidebar || !backdrop) return;
    btn.classList.add('is-open');
    sidebar.classList.add('is-open');
    // Show backdrop with pointer-events only when open
    backdrop.style.display = 'block';
    requestAnimationFrame(() => backdrop.classList.add('is-open'));
    btn.setAttribute('aria-expanded', 'true');
    btn.setAttribute('aria-label', 'Close menu');
    sidebar.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function close() {
    if (!btn || !sidebar || !backdrop) return;
    btn.classList.remove('is-open');
    sidebar.classList.remove('is-open');
    backdrop.classList.remove('is-open');
    // Hide backdrop after transition ends
    backdrop.addEventListener('transitionend', () => {
      if (!backdrop.classList.contains('is-open')) backdrop.style.display = 'none';
    }, { once: true });
    btn.setAttribute('aria-expanded', 'false');
    btn.setAttribute('aria-label', 'Open menu');
    sidebar.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  btn?.addEventListener('click', () => btn.classList.contains('is-open') ? close() : open());
  closeBtn?.addEventListener('click', close);
  backdrop?.addEventListener('click', close);
  sidebar?.querySelectorAll('a').forEach(a => a.addEventListener('click', close));
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && btn?.classList.contains('is-open')) { close(); btn.focus(); }
  });
</script>
