---
import Icon from '~/components/icons/Icon.astro';
import LazyImage from '~/components/ui/LazyImage.astro';
import { SITE, waUrl } from '~/data/site';
import type { Lang } from '~/i18n/index';
import { useTranslations } from '~/i18n/index';
interface Props { lang?: Lang }
const { lang = 'en' } = Astro.props;
const t = await useTranslations(lang);
const waChatUrl = waUrl(`Hi Media Pro, I'd like to chat about your services.`);
const homeHref = lang === 'en' ? '/' : `/${lang}`;
const termsHref = lang === 'en' ? '/terms' : `/${lang}/terms`;
const disclaimerHref = lang === 'en' ? '/disclaimer' : `/${lang}/disclaimer`;
const faqHref = lang === 'en' ? '/faq' : `/${lang}/faq`;
const contactHref = lang === 'en' ? '/contact' : `/${lang}/contact`;
---
<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div>
        <a href={homeHref} class="brand brand-footer" aria-label="Media Pro — Home">
          <LazyImage
            src="/logo-text.webp"
            alt="Media Pro"
            width={120}
            height={40}
          />
        </a>
        <p class="footer-tag">{t('footer.tagline')}</p>
      </div>
      <div><p class="footer-col-title">{t('footer.col_services')}</p><ul><li>Web Development</li><li>Google Ads Services</li><li>Meta Ads Services</li><li>Consulting Services</li></ul></div>
      <div><p class="footer-col-title">{t('footer.col_company')}</p><ul><li><a href={termsHref}>{t('footer.link_terms')}</a></li><li><a href={disclaimerHref}>{t('footer.link_disclaimer')}</a></li><li><a href={faqHref}>{t('footer.link_faq')}</a></li><li><a href={contactHref}>{t('footer.link_contact')}</a></li></ul></div>
      <div><p class="footer-col-title">{t('footer.col_contact')}</p><ul><li><a href={`mailto:${SITE.email}`}>{SITE.email}</a></li><li><a href={waChatUrl} target="_blank" rel="noopener noreferrer">{SITE.phoneDisplay} — {t('footer.wa_label')}</a></li></ul></div>
    </div>
    <div class="footer-bottom">
      <span>{t('footer.copyright')}</span>
      <div class="socials">
        <a href={SITE.social.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram"><Icon name="instagram" size={16} /></a>
        <a href={SITE.social.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn"><Icon name="linkedin" size={16} /></a>
      </div>
    </div>
  </div>
</footer>
