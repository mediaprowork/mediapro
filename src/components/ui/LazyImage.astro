---
interface Props {
  src: string;
  alt: string;
  width?: number;
  height?: number;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
  decoding?: 'async' | 'sync' | 'auto';
  class?: string;
  wrapperClass?: string;
}

const {
  src, alt, width, height,
  loading = 'lazy',
  fetchpriority,
  decoding = 'async',
  class: imgClass,
  wrapperClass,
} = Astro.props;
---

<div class:list={['lazy-img', wrapperClass]}>
  <img
    src={src}
    alt={alt}
    width={width}
    height={height}
    loading={loading}
    fetchpriority={fetchpriority}
    decoding={decoding}
    class={imgClass}
    onload="this.parentElement.classList.add('loaded')"
  />
</div>

<script>
  document.querySelectorAll('.lazy-img img').forEach((img) => {
    if ((img as HTMLImageElement).complete) {
      img.parentElement?.classList.add('loaded');
    }
  });
</script>
