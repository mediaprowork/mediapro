---
// Floating dark/light mode toggle. Position: fixed bottom-right.
// Click to flip <html data-theme>. Initial state set by inline anti-flash
// script in BaseLayout.astro before paint to prevent flash.
---
<button
  class="theme-toggle"
  id="themeToggle"
  type="button"
  aria-label="Toggle dark mode"
  aria-pressed="false"
>
  <!-- Moon icon (visible in light mode → click to go dark) -->
  <svg class="theme-icon theme-moon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
  </svg>
  <!-- Sun icon (visible in dark mode → click to go light) -->
  <svg class="theme-icon theme-sun" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <circle cx="12" cy="12" r="4" fill="currentColor"/>
    <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>
  </svg>
</button>

<script>
  import '~/lib/theme-toggle';
</script>
