---
import { PUBLIC_GA_ID } from 'astro:env/client';
---
{PUBLIC_GA_ID && (
  <>
    <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${PUBLIC_GA_ID}`}></script>
    <script is:inline define:vars={{ gaId: PUBLIC_GA_ID }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){ dataLayer.push(arguments); }
      gtag('js', new Date());
      gtag('config', gaId);
    </script>
  </>
)}
