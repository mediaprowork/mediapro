---
import { getCollection } from 'astro:content';
import LazyImage from '~/components/ui/LazyImage.astro';
import type { Lang } from '~/i18n/index';
import { useTranslations } from '~/i18n/index';
interface Props { lang?: Lang }
const { lang = 'en' } = Astro.props;
const t = await useTranslations(lang);
const logos = await getCollection('trustedLogos');
const tripled = [...logos, ...logos, ...logos];
---
<section class="trusted" aria-label="Trusted brands and organizations">
  <div class="container">
    <p class="trusted-label">{t('marquee.label')}</p>
  </div>
  <div class="marquee" aria-hidden="true">
    <div class="marquee-track">
      {tripled.map((logo) => (
        <LazyImage
          src={logo.data.src}
          alt={`${logo.data.alt} — Media Pro client logo`}
          loading="lazy"
          height={52}
          width={120}
        />
      ))}
    </div>
  </div>
</section>
