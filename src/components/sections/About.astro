---
import Reveal from '~/components/ui/Reveal.astro';
import Icon from '~/components/icons/Icon.astro';
import { waUrl } from '~/data/site';
import type { Lang } from '~/i18n/index';
import { useTranslations } from '~/i18n/index';
interface Props { lang?: Lang }
const { lang = 'en' } = Astro.props;
const t = await useTranslations(lang);
const waAboutUrl = waUrl(`Hi Media Pro, I'd like to learn more about your digital marketing services.`);
---
<section id="about" aria-labelledby="about-heading">
  <div class="container">
    <div class="about-grid">
      <div class="about-copy">
        <Reveal><span class="eyebrow">{t('about.eyebrow')}</span></Reveal>
        <Reveal delay={1}>
          <h2 id="about-heading" class="h-section">
            {t('about.heading')} <span style="color:var(--gold-dark);font-style:italic;font-weight:500;">{t('about.accent')}</span> {t('about.heading_end')}
          </h2>
        </Reveal>
        <Reveal delay={2}>
          <p class="lede" style="margin-top:24px;">
            {t('about.lede')}
          </p>
        </Reveal>

        <Reveal delay={3} class="about-bullets">
          <div class="bullet">
            <span class="icon-wrap"><Icon name="thumbs-up" /></span>
            <span>{t('about.bullet_1')}</span>
          </div>
          <div class="bullet">
            <span class="icon-wrap"><Icon name="cloud" /></span>
            <span>{t('about.bullet_2')}</span>
          </div>
        </Reveal>

        <Reveal delay={4}>
          <a href={waAboutUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
            {t('about.cta')}
            <Icon name="arrow-right" size={14} />
          </a>
        </Reveal>
      </div>

      <Reveal delay={2} class="about-visual">
        <img
          class="img-light"
          src="/images/about-mockup.png"
          alt="Media Pro mobile app showcasing digital marketing analytics"
          width="414"
          height="600"
          loading="lazy"
        />
        <img
          class="img-dark"
          src="/images/about-mockup-dark.png"
          alt="Media Pro mobile app showcasing digital marketing analytics"
          width="414"
          height="600"
          loading="lazy"
        />
      </Reveal>
    </div>

    <div class="vmm">
      <Reveal>
        <span class="icon-wrap"><Icon name="rocket" /></span>
        <h4>{t('about.vision_h')}</h4>
        <p>{t('about.vision_p')}</p>
      </Reveal>
      <Reveal delay={1}>
        <span class="icon-wrap"><Icon name="compass" /></span>
        <h4>{t('about.mission_h')}</h4>
        <p>{t('about.mission_p')}</p>
      </Reveal>
      <Reveal delay={2}>
        <span class="icon-wrap"><Icon name="handshake" /></span>
        <h4>{t('about.motto_h')}</h4>
        <p>{t('about.motto_p')}</p>
      </Reveal>
    </div>
  </div>
</section>
