---
import Reveal from '~/components/ui/Reveal.astro';
import Icon from '~/components/icons/Icon.astro';
import { waUrl } from '~/data/site';
import type { Lang } from '~/i18n/index';
import { useTranslations } from '~/i18n/index';
interface Props { lang?: Lang }
const { lang = 'en' } = Astro.props;
const t = await useTranslations(lang);
const waConsultUrl = waUrl(`Hi Media Pro, I'd like a free consultation about your services.`);
---
<section>
  <div class="container">
    <div class="services-intro-grid">
      <Reveal class="visual">
        <div class="lazy-img">
          <picture>
            <source
              srcset="/images/services-visual-dark.webp"
              media="(prefers-color-scheme: dark)"
            />
            <img
              src="/images/services-visual.webp"
              alt="Strategy in action — Media Pro digital marketing"
              width="600"
              height="600"
              loading="lazy"
              decoding="async"
              onload="this.closest('.lazy-img').classList.add('loaded')"
            />
          </picture>
        </div>
      </Reveal>

      <div>
        <Reveal><span class="eyebrow">{t('services_intro.eyebrow')}</span></Reveal>
        <Reveal delay={1}>
          <h2 class="h-section" style="margin-top:22px;">{t('services_intro.heading')}</h2>
        </Reveal>
        <Reveal delay={2}>
          <p class="lede" style="margin-top:22px;">
            {t('services_intro.lede')}
          </p>
        </Reveal>

        <Reveal delay={3}>
          <div class="highlight-box">
            <span class="icon-wrap"><Icon name="people" /></span>
            <div>
              <h4>{t('services_intro.highlight_h')}</h4>
              <p>{t('services_intro.highlight_p')}</p>
            </div>
          </div>
        </Reveal>

        <Reveal delay={4}>
          <a href={waConsultUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
            {t('services_intro.cta')}
            <Icon name="arrow-right" size={14} />
          </a>
        </Reveal>
      </div>
    </div>
  </div>
</section>
