---
import Reveal from '~/components/ui/Reveal.astro';
import Icon from '~/components/icons/Icon.astro';
import LazyImage from '~/components/ui/LazyImage.astro';
import { getCollection } from 'astro:content';
import type { Lang } from '~/i18n/index';
import { useTranslations } from '~/i18n/index';
interface Props { lang?: Lang }
const { lang = 'en' } = Astro.props;
const t = await useTranslations(lang);
const testimonials = await getCollection('testimonials');
---
<section>
  <div class="container">
    <Reveal>
      <div class="section-head">
        <div>
          <span class="eyebrow">{t('testimonials.eyebrow')}</span>
          <h2 class="h-section" style="margin-top:18px;">{t('testimonials.heading')}</h2>
        </div>
      </div>
    </Reveal>

    <div class="growth-stats">
      <Reveal delay={1}>
        <div class="growth-card">
          <span class="icon-wrap"><Icon name="arrow-up" size={26} /></span>
          <div>
            <span class="num">{t('testimonials.growth_1_num')}</span>
            <h5>{t('testimonials.growth_1_h')}</h5>
            <p>{t('testimonials.growth_1_p')}</p>
          </div>
        </div>
      </Reveal>
      <Reveal delay={2}>
        <div class="growth-card">
          <span class="icon-wrap"><Icon name="arrow-up" size={26} /></span>
          <div>
            <span class="num">{t('testimonials.growth_2_num')}</span>
            <h5>{t('testimonials.growth_2_h')}</h5>
            <p>{t('testimonials.growth_2_p')}</p>
          </div>
        </div>
      </Reveal>
    </div>

    <div class="testimonials-track">
      {testimonials.map((tl, i) => (
        <Reveal delay={((i % 3) + 1) as 1 | 2 | 3}>
          <div class="testimonial">
            <p>{tl.data.quote}</p>
            <div class="testimonial-author">
              <LazyImage
                src={tl.data.img}
                alt={tl.data.name}
                width={44}
                height={44}
                wrapperClass="avatar-skeleton"
              />
              <div>
                <strong>{tl.data.name}</strong>
                <span>{tl.data.role}</span>
              </div>
            </div>
          </div>
        </Reveal>
      ))}
    </div>
  </div>
</section>
