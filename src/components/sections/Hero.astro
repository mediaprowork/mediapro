---
import Reveal from '~/components/ui/Reveal.astro';
import Icon from '~/components/icons/Icon.astro';
import { SITE, waUrl } from '~/data/site';
import type { Lang } from '~/i18n/index';
import { useTranslations } from '~/i18n/index';
interface Props { lang?: Lang }
const { lang = 'en' } = Astro.props;
const t = await useTranslations(lang);
const waHeroUrl = waUrl(`Hi Media Pro, I'd like to schedule a free consultation.`);
---
<section class="hero" id="top" aria-labelledby="hero-heading">
  <div class="container">
    <div class="hero-grid">
      <div class="hero-copy">
        <Reveal><span class="eyebrow">{t('hero.eyebrow')}</span></Reveal>
        <Reveal delay={1}>
          <h1 id="hero-heading" class="h-display">
            {t('hero.heading')} <span class="accent">{t('hero.accent')}</span> {t('hero.heading_end')}
          </h1>
        </Reveal>
        <Reveal delay={2}>
          <p class="lede">
            <strong>{t('hero.lede_strong')}</strong>
            {' '}{t('hero.lede_rest').replace('{brands}', SITE.stats.brandsServed).replace('{countries}', SITE.stats.countries).replace('{rating}', SITE.stats.rating)}
          </p>
        </Reveal>
        <Reveal delay={3} class="hero-actions">
          <a href="#about" class="btn btn-primary">
            {t('hero.btn_primary')}
            <Icon name="arrow-right" size={14} />
          </a>
          <a
            href={waHeroUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-ghost"
          >
            {t('hero.btn_secondary')}
          </a>
        </Reveal>

        <Reveal delay={4} class="hero-meta">
          <div class="m">
            <strong>{SITE.stats.yearsExperience} yrs</strong>
            <span>{t('hero.meta_yrs')}</span>
          </div>
          <div class="m">
            <strong>{SITE.stats.brandsServed}</strong>
            <span>{t('hero.meta_brands')}</span>
          </div>
          <div class="m">
            <strong>{SITE.stats.rating}★</strong>
            <span>{t('hero.meta_rating')}</span>
          </div>
        </Reveal>
      </div>

      <Reveal delay={2} class="phone-stage">
        <div class="stage-ring stage-ring-1"></div>
        <div class="stage-ring stage-ring-2"></div>
        <div class="stage-ring stage-ring-3"></div>

        <div class="chip chip-1">
          <Icon name="arrow-up" size={14} />
          <span>{t('hero.chip_engagement')} <span class="red">+180%</span></span>
        </div>
        <div class="chip chip-2">
          <Icon name="stars" size={14} />
          <span>{t('hero.chip_conversion')} <span class="gold">+45%</span></span>
        </div>
        <div class="chip chip-3">
          <Icon name="people" size={14} />
          <span>{t('hero.chip_reach')} <span class="red">2.4M</span></span>
        </div>

        <img
          class="phone img-light"
          src="/images/hero-phone.png"
          alt="Media Pro digital marketing dashboard preview on mobile"
          width="320"
          height="640"
          loading="eager"
          fetchpriority="high"
        />
        <img
          class="phone img-dark"
          src="/images/hero-phone-dark.png"
          alt="Media Pro digital marketing dashboard preview on mobile"
          width="320"
          height="640"
          loading="lazy"
        />
      </Reveal>
    </div>
  </div>
</section>
