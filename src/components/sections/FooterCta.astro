---
import Reveal from '~/components/ui/Reveal.astro';
import Icon from '~/components/icons/Icon.astro';
import { waUrl } from '~/data/site';
import type { Lang } from '~/i18n/index';
import { useTranslations } from '~/i18n/index';
interface Props { lang?: Lang }
const { lang = 'en' } = Astro.props;
const t = await useTranslations(lang);
const waStartUrl = waUrl(`Hi Media Pro, I'm ready to scale and I'd like to get started with a project.`);
---
<section class="footer-cta">
  <div class="container">
    <div>
      <Reveal><span class="eyebrow">{t('footer_cta.eyebrow')}</span></Reveal>
      <Reveal delay={1}>
        <h2 class="h-display" style="font-size:clamp(36px,5vw,72px);">
          {t('footer_cta.heading_pre')} <span class="accent">{t('footer_cta.accent')}</span>{t('footer_cta.heading_end')}
        </h2>
      </Reveal>
      <Reveal delay={2}>
        <div style="display:flex;gap:14px;flex-wrap:wrap;">
          <a href={waStartUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
            {t('footer_cta.btn_primary')}
            <Icon name="arrow-right" size={14} />
          </a>
          <a href="mailto:admin@mediapro.work" class="btn btn-ghost">
            admin@mediapro.work
          </a>
        </div>
      </Reveal>
    </div>
    <Reveal delay={2} class="visual">
      <div class="lazy-img">
        <picture>
          <source
            srcset="/images/footer-cta-dark.webp"
            media="(prefers-color-scheme: dark)"
          />
          <img
            src="/images/footer-cta.webp"
            alt="Grow with Media Pro"
            width="500"
            height="500"
            loading="lazy"
            decoding="async"
            onload="this.closest('.lazy-img').classList.add('loaded')"
          />
        </picture>
      </div>
    </Reveal>
  </div>
</section>
