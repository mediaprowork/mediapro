---
import Reveal from '~/components/ui/Reveal.astro';
import Icon from '~/components/icons/Icon.astro';
import { waUrl } from '~/data/site';
const waStartUrl = waUrl(`Hi Media Pro, I'm ready to scale and I'd like to get started with a project.`);
---
<section class="footer-cta">
  <div class="container">
    <div>
      <Reveal><span class="eyebrow">Get in touch</span></Reveal>
      <Reveal delay={1}>
        <h2 class="h-display" style="font-size:clamp(36px,5vw,72px);">
          Ready to scale? Bring us your <span class="accent">best idea</span>.
        </h2>
      </Reveal>
      <Reveal delay={2}>
        <div style="display:flex;gap:14px;flex-wrap:wrap;">
          <a href={waStartUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
            Get Started
            <Icon name="arrow-right" size={14} />
          </a>
          <a href="mailto:admin@mediapro.work" class="btn btn-ghost">
            admin@mediapro.work
          </a>
        </div>
      </Reveal>
    </div>
    <Reveal delay={2} class="visual">
      <img src="/images/footer-cta.png" alt="Grow with Media Pro" loading="lazy" width="500" height="500" />
    </Reveal>
  </div>
</section>
