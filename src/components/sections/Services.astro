---
import type { Lang } from '~/i18n/index';
import { useTranslations } from '~/i18n/index';
import { getCollection } from 'astro:content';
import Reveal from '~/components/ui/Reveal.astro';
import Icon from '~/components/icons/Icon.astro';

interface Props { lang?: Lang }
const { lang = 'en' } = Astro.props;
const t = await useTranslations(lang);

type ServiceData = { id: string; num: string; icon: string; title: string; desc: string };
let services: { data: ServiceData }[];
if (lang === 'en') {
  const enCol = await getCollection('services');
  services = enCol
    .map((s) => ({ data: s.data as ServiceData }))
    .sort((a, b) => a.data.num.localeCompare(b.data.num));
} else {
  const mod = await import(`~/i18n/content/${lang}/services.json`);
  services = (mod.default as ServiceData[])
    .sort((a, b) => a.num.localeCompare(b.num))
    .map((data) => ({ data }));
}
---
<section id="services" aria-labelledby="services-heading">
  <div class="container">
    <Reveal>
      <div class="section-head">
        <div>
          <span class="eyebrow">{t('services.eyebrow')}</span>
          <h2 id="services-heading" class="h-section" style="margin-top:18px;">
            {t('services.heading')}
          </h2>
        </div>
        <p class="right">
          {t('services.sub')}
        </p>
      </div>
    </Reveal>

    <Reveal>
      <div class="services-grid" role="list">
        {services.map((s) => (
          <article class="service-card" role="listitem" itemscope itemtype="https://schema.org/Service">
            <span class="num">{s.data.num} / 06</span>
            <span class="icon-wrap" aria-hidden="true"><Icon name={s.data.icon} size={26} /></span>
            <h3 itemprop="name">{s.data.title}</h3>
            <p itemprop="description">{s.data.desc}</p>
            <meta itemprop="provider" content="Media Pro Creative Limited" />
          </article>
        ))}
      </div>
    </Reveal>
  </div>
</section>
